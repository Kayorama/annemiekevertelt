{
  "project": {
    "name": "RenderOwl",
    "description": "AI-powered video generation platform",
    "environments": ["staging", "production"]
  },
  "staging": {
    "domain": "staging.renderowl.com",
    "branch": "develop",
    "auto_deploy": true,
    "environment_variables": [
      "NODE_ENV=staging",
      "API_URL=https://api.staging.renderowl.com",
      "WEB_URL=https://staging.renderowl.com"
    ]
  },
  "production": {
    "domain": "renderowl.com",
    "branch": "main",
    "auto_deploy": false,
    "requires_approval": true,
    "environment_variables": [
      "NODE_ENV=production",
      "API_URL=https://api.renderowl.com",
      "WEB_URL=https://renderowl.com"
    ]
  },
  "services": {
    "postgres": {
      "type": "postgresql",
      "version": "16",
      "backups": {
        "enabled": true,
        "frequency": "0 2 * * *",
        "retention_days": 30
      }
    },
    "redis": {
      "type": "redis",
      "version": "7",
      "persistence": true
    }
  },
  "applications": [
    {
      "name": "renderowl-api",
      "type": "dockerfile",
      "dockerfile_path": "backend/Dockerfile.prod",
      "port": 8080,
      "health_check": "/health",
      "resources": {
        "cpu": "2",
        "memory": "4Gi"
      }
    },
    {
      "name": "renderowl-web",
      "type": "dockerfile",
      "dockerfile_path": "frontend/Dockerfile.prod",
      "port": 3000,
      "health_check": "/api/health",
      "resources": {
        "cpu": "1",
        "memory": "2Gi"
      }
    },
    {
      "name": "renderowl-worker-render",
      "type": "dockerfile",
      "dockerfile_path": "backend/Dockerfile.worker",
      "command": "./worker -queue render",
      "replicas": 3,
      "resources": {
        "cpu": "4",
        "memory": "8Gi"
      }
    },
    {
      "name": "renderowl-worker-export",
      "type": "dockerfile",
      "dockerfile_path": "backend/Dockerfile.worker",
      "command": "./worker -queue export",
      "replicas": 2,
      "resources": {
        "cpu": "2",
        "memory": "4Gi"
      }
    }
  ],
  "ssl": {
    "staging": {
      "enabled": true,
      "letsencrypt": true
    },
    "production": {
      "enabled": true,
      "letsencrypt": true
    }
  }
}
