# RenderOwl Production Environment Variables
# Copy to .env and fill in actual values

# ============================================
# Database
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=renderowl
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgres://postgres:your_secure_password_here@postgres:5432/renderowl

# ============================================
# Redis
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ============================================
# API Keys - Replicate (AI Video Generation)
# ============================================
REPLICATE_API_TOKEN=r8_your_token_here

# ============================================
# Authentication - Clerk
# ============================================
CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
CLERK_SECRET_KEY=sk_live_your_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_key_here

# ============================================
# Storage - Cloudflare R2
# ============================================
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=renderowl-prod
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# ============================================
# Monitoring - Sentry
# ============================================
SENTRY_DSN=https://your_key@sentry.io/your_project
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project

# ============================================
# Payments - Stripe
# ============================================
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ============================================
# Social Platform OAuth
# ============================================
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
TIKTOK_CLIENT_ID=your_tiktok_client_id
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ============================================
# Backup Configuration
# ============================================
BACKUP_RETENTION_DAYS=30
S3_BACKUP_BUCKET=renderowl-backups
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_DEFAULT_REGION=auto

# ============================================
# Application Settings
# ============================================
NODE_ENV=production
PORT=8080
WEB_URL=https://renderowl.com
API_URL=https://api.renderowl.com
RENDEROWL_VERSION=1.0.0

# ============================================
# Worker Configuration
# ============================================
WORKER_CONCURRENCY=5
RENDER_TIMEOUT=600
EXPORT_TIMEOUT=300

# ============================================
# Notifications
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
PAGERDUTY_KEY=your_pagerduty_key

# ============================================
# Coolify (for deployment scripts)
# ============================================
COOLIFY_TOKEN=your_coolify_api_token
COOLIFY_API_URL=https://app.coolify.io/api/v1

# ============================================
# Sentry CLI (for monitoring setup)
# ============================================
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=renderowl
