    "build:cms": "cd apps/cms && pnpm build",
    "start": "docker-compose up -d",
    "stop": "docker-compose down"
  },
  "devDependencies": {
    "@types/node": "^20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "esbuild"]
  }
}
