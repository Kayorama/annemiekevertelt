{
  "name": "annemiekevertelt",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "cd apps/web && pnpm dev",
    "dev:cms": "cd apps/cms && pnpm dev",
    "build": "pnpm -r build",
