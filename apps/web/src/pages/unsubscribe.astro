---
import Layout from '../layouts/Layout.astro';

const email = Astro.url.searchParams.get('email') || '';
let message = '';
let isSuccess = false;

if (email) {
  try {
    const response = await fetch(`${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}/api/unsubscribe?email=${encodeURIComponent(email)}`);
    const data = await response.json();
    message = data.message || 'Je bent uitgeschreven.';
    isSuccess = response.ok;
  } catch (error) {
    message = 'Er ging iets mis. Probeer het later opnieuw of neem contact op.';
    isSuccess = false;
  }
}
---

<Layout title="Uitschrijven - Annemieke Vertelt" description="Uitschrijven van de nieuwsbrief">
  <div class="min-h-screen flex items-center justify-center px-6 py-20">
    <div class="max-w-md w-full text-center">
      <div class="mb-8">
        <svg class="w-16 h-16 mx-auto text-gold mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        <h1 class="font-serif text-3xl text-dark-brown mb-2">
          {email ? (isSuccess ? 'Je bent uitgeschreven' : 'Er ging iets mis') : 'Uitschrijven'}
        </h1>
      </div>

      {email ? (
        <div class={`p-6 rounded-2xl ${isSuccess ? 'bg-green-50 border border-green-200' : 'bg-red-50 border border-red-200'}`}>
          <p class={isSuccess ? 'text-green-800' : 'text-red-800'}>
            {message}
          </p>
          {isSuccess && (
            <p class="text-green-600 text-sm mt-2">
              Je ontvangt geen nieuwsbrieven meer van Annemieke Vertelt.
            </p>
          )}
        </div>
      ) : (
        <div class="bg-cream-dark/30 p-8 rounded-2xl">
          <p class="text-text-muted mb-6">
            Vul hieronder je e-mailadres in om uit te schrijven van de nieuwsbrief.
          </p>
          
          <form id="unsubscribe-form" class="space-y-4">
            <input 
              type="email" 
              name="email"
              placeholder="je@email.nl" 
              required
              class="w-full px-5 py-3 rounded-full border border-gold/30 bg-white focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-center"
            />
            <button 
              type="submit" 
              class="w-full px-8 py-3 rounded-full bg-warm-brown text-cream font-medium hover:bg-dark-brown transition-colors"
            >
              Uitschrijven
            </button>
          </form>
          
          <p id="unsubscribe-message" class="mt-4 text-sm hidden"></p>
        </div>
      )}

      <div class="mt-8">
        <a href="/" class="text-warm-brown hover:text-dark-brown transition-colors">
          ← Terug naar home
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('unsubscribe-form');
  const message = document.getElementById('unsubscribe-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get('email');
    
    // Reload the page with the email parameter
    window.location.href = `/unsubscribe?email=${encodeURIComponent(email as string)}`;
  });
</script>
