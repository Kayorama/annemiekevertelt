---
import { formatDate } from '../lib/date';

interface Props {
  href: string;
  title: string;
  excerpt?: string;
  image?: any;
  date?: string;
  category: string;
  ageGroup?: string;
  duration?: string;
  demo?: boolean;
}

const { 
  href, 
  title, 
  excerpt, 
  image, 
  date, 
  category, 
  ageGroup,
  duration,
  demo = false 
} = Astro.props;

const imageUrl = image ? `${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${image.url}` : null;
---

<a 
  href={href}
  class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500"
  data-astro-prefetch
>
  <!-- Image -->
  <div class="aspect-[16/10] overflow-hidden bg-cream-dark">
    {imageUrl ? (
      <img 
        src={imageUrl}
        alt={image.alt || title}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
      />
    ) : demo ? (
      <div class="w-full h-full bg-gradient-to-br from-gold/20 to-warm-brown/10 flex items-center justify-center">
        <svg class="w-16 h-16 text-gold/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    ) : (
      <div class="w-full h-full bg-cream-dark flex items-center justify-center">
        <svg class="w-16 h-16 text-gold/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-6">
    <!-- Meta -->
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs font-medium tracking-wider uppercase text-gold">
        {category}
      </span>
      {ageGroup && (
        <span class="text-xs text-text-muted">· {ageGroup}</span>
      )}
      {duration && (
        <span class="text-xs text-text-muted">· {duration}</span>
      )}
    </div>

    <!-- Title -->
    <h3 class="font-serif text-xl text-dark-brown mb-2 group-hover:text-warm-brown transition-colors line-clamp-2">
      {title}
    </h3>

    <!-- Excerpt -->
    {excerpt && (
      <p class="text-text-muted text-sm line-clamp-2">
        {excerpt}
      </p>
    )}

    <!-- Date -->
    {date && (
      <div class="flex items-center gap-2 mt-4 pt-4 border-t border-gold/20">
        <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <time class="text-xs text-text-muted" datetime={date}>
          {formatDate(date)}
        </time>
      </div>
    )}
  </div>
</a>
