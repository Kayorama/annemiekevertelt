---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import StoryCard from '../../components/StoryCard.astro';
import { fetchPayload } from '../../lib/payload';
import { GraduationCap, Heart, Baby, Briefcase } from 'lucide-react';

const { docs: aboutMePosts } = await fetchPayload({
  collection: 'about-me',
  limit: 12,
  where: { draft: { equals: false } },
}).catch(() => ({ docs: [] }));

const chapters = [
  {
    title: 'School & Jeugd',
    icon: GraduationCap,
    description: 'Waar het allemaal begon, met boeken en dromen',
    color: 'from-gold/30 to-gold/10',
  },
  {
    title: 'Huwelijk',
    icon: Heart,
    description: 'Liefde, avontuur en samen groeien',
    color: 'from-warm-brown/30 to-warm-brown/10',
  },
  {
    title: 'Kinderen',
    icon: Baby,
    description: 'Het mooiste verhaal dat ik ooit schreef',
    color: 'from-dark-brown/30 to-dark-brown/10',
  },
  {
    title: 'Carrière',
    icon: Briefcase,
    description: 'Van droom naar werkelijkheid',
    color: 'from-gold-light/40 to-gold/20',
  },
];
---

<Layout 
  title="Over zichzelf | Annemieke Vertelt"
  description="Het verhaal achter het verhaal."
>
  <Navigation />

  <main class="pt-32 pb-20">
    <div class="container-wide">
      <!-- Header -->
      <div class="text-center mb-16">
        <p class="text-warm-brown font-serif italic text-lg mb-2">Annemieke vertelt…</p>
        
        <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl text-dark-brown mb-4">
          …over zichzelf
        </h1>
        
        <div class="flex items-center justify-center gap-4 mb-6">
          <div class="w-12 h-px bg-gold"></div>
          <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <div class="w-12 h-px bg-gold"></div>
        </div>
        
        <p class="text-text-muted max-w-lg mx-auto">
          Het verhaal achter het verhaal. Waarom ik schrijf, 
          wat mij drijft, en wie ik ben.
        </p>
      </div>

      <!-- Life Chapters Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-20">
        {chapters.map((chapter) => (
          <div class="group bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class:list={[
              'w-16 h-16 rounded-2xl flex items-center justify-center mb-4 bg-gradient-to-br',
              chapter.color
            ]}>
              <chapter.icon class="w-8 h-8 text-warm-brown" />
            </div>
            
            <h3 class="font-serif text-xl text-dark-brown mb-2">{chapter.title}</h3>
            
            <p class="text-text-muted text-sm">{chapter.description}</p>
          </div>
        ))}
      </div>

      <!-- Quote Section -->
      <div class="max-w-3xl mx-auto mb-20 text-center">
        <blockquote class="relative">
          <svg class="w-12 h-12 mx-auto mb-6 text-gold/30" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          
          <p class="font-serif text-2xl sm:text-3xl text-dark-brown italic leading-relaxed mb-6"
          >
            "Ik schrijf omdat ik anders niet zou weten wie ik ben. 
            Elke zin is een stap dichter bij mezelf."
          </p>
          
          <cite class="text-warm-brown not-italic">— Annemieke</cite>
        </blockquote>
      </div>

      <!-- Stories Grid -->
      <div class="mb-12">
        <h2 class="font-serif text-3xl text-dark-brown text-center mb-12">Persoonlijke verhalen</h2>

        {aboutMePosts.length > 0 ? (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {aboutMePosts.map((post: any) => (
              <StoryCard 
                href={`/over-zichzelf/${post.slug}`}
                title={post.title}
    excerpt={post.excerpt}
                image={post.featuredImage}
                date={post.publishedDate}
                category="Over zichzelf"
              />
            ))}
          </div>
        ) : (
          <!-- Demo Content -->
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {[
              { title: 'Hoe het begon', desc: 'Het verhaal achter Annemieke Vertelt en waarom ik begon met schrijven...' },
              { title: 'Mijn eerste boek', desc: 'De nervositeit, het wachten, en het moment dat het echt was...' },
              { title: 'Waarom verhalen', desc: 'Over de kracht van een goed verhaal en waarom ze ons mens maken...' },
            ].map((story) => (
              <StoryCard 
                href="#"
                title={story.title}
                excerpt={story.desc}
                category="Over zichzelf"
                demo={true}
              />
            ))}
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
