---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Newspaper, BookOpen, Headphones, User } from 'lucide-react';

const categories = [
  {
    href: '/columns',
    label: '…in columns',
    description: 'Gedachten, observaties & reflecties',
    icon: Newspaper,
    color: 'from-gold/30 to-gold/10',
    iconColor: 'text-gold',
  },
  {
    href: '/verhalen',
    label: '…verhalen voor kinderen',
    description: 'Magische verhalen voor kleine oren',
    icon: BookOpen,
    color: 'from-warm-brown/30 to-warm-brown/10',
    iconColor: 'text-warm-brown',
  },
  {
    href: '/hardop',
    label: '…hardop',
    description: 'Voorleesverhalen om naar te luisteren',
    icon: Headphones,
    color: 'from-dark-brown/30 to-dark-brown/10',
    iconColor: 'text-dark-brown',
  },
  {
    href: '/over-zichzelf',
    label: '…over zichzelf',
    description: 'Het verhaal achter het verhaal',
    icon: User,
    color: 'from-gold-light/40 to-gold/20',
    iconColor: 'text-gold',
  },
];
---

<Layout>
  <Navigation transparent={true} />

  <!-- Hero Section -->
  <section class="min-h-screen flex flex-col justify-center items-center relative pt-20 pb-32 px-6">
    <!-- Subtle background pattern -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 -left-32 w-64 h-64 bg-gold/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/3 -right-32 w-96 h-96 bg-warm-brown/5 rounded-full blur-3xl"></div>
    </div>

    <div class="text-center max-w-3xl mx-auto relative">
      <!-- Main Title -->
      <h1 class="font-serif text-5xl sm:text-6xl md:text-7xl lg:text-8xl text-dark-brown mb-6 leading-tight">
        Annemieke vertelt…
      </h1>
      
      <!-- Tagline -->
      <p class="font-serif italic text-2xl sm:text-3xl text-warm-brown mb-16">
        Mocht je me gemist hebben…
      </p>

      <!-- Decorative element -->
      <div class="flex items-center justify-center gap-4 mb-16">
        <div class="w-16 h-px bg-gradient-to-r from-transparent to-gold"></div>
        <svg class="w-8 h-8 text-gold" viewBox="0 0 32 32" fill="none">
          <rect width="32" height="32" rx="8" fill="currentColor" fill-opacity="0.2"/>
          <path d="M8 12C8 10.8954 8.89543 10 10 10H22C23.1046 10 24 10.8954 24 12V24C24 25.1046 23.1046 26 22 26H10C8.89543 26 8 25.1046 8 24V12Z" fill="currentColor" fill-opacity="0.4"/>
        </svg>
        <div class="w-16 h-px bg-gradient-to-l from-transparent to-gold"></div>
      </div>

      <!-- Category Grid -->
      <div class="grid sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        {categories.map((category, index) => (
          <a 
            href={category.href}
            class="group relative bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1 overflow-hidden"
            style={`animation-delay: ${index * 100}ms`}
          >
            <!-- Background gradient -->
            <div class:list={[
              'absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500',
              category.color
            ]}></div>
            
            <div class="relative flex items-start gap-4">
              <div class="category-icon shrink-0 group-hover:scale-110 group-hover:border-warm-brown transition-all duration-300">
                <category.icon class:list={['w-8 h-8', category.iconColor]} />
              </div>
              <div class="text-left">
                <h2 class="font-serif text-xl text-dark-brown mb-1 group-hover:text-warm-brown transition-colors">
                  {category.label}
                </h2>
                <p class="text-text-muted text-sm">
                  {category.description}
                </p>
              </div>
            </div>

            <!-- Arrow indicator -->
            <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300">
              <svg class="w-5 h-5 text-warm-brown" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
      <span class="text-xs text-text-muted uppercase tracking-widest">Ontdek</span>
      <div class="w-px h-12 bg-gradient-to-b from-gold to-transparent"></div>
    </div>
  </section>

  <!-- Latest Stories Section -->
  <import LatestStories from '../components/LatestStories.astro'>
    <LatestStories />
  </import>

  <!-- Newsletter Section -->
  <section class="py-20 bg-cream-dark/30">
    <div class="container-readable text-center">
      <div class="max-w-xl mx-auto">
        <svg class="w-12 h-12 mx-auto mb-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        
        <h2 class="font-serif text-3xl text-dark-brown mb-4">Blijf op de hoogte</h2>
        <p class="text-text-muted mb-8">
          Ontvang een berichtje wanneer er een nieuw verhaal online staat. 
          Geen spam, alleen verhalen.
        </p>

        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3">
          <input 
            type="text"
            name="name"
    placeholder="Je naam (optioneel)"
            class="flex-1 px-5 py-3 rounded-full border border-gold/30 bg-white focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all"
          />
          <input 
            type="email" 
    name="email"
            placeholder="je@email.nl" 
            required
            class="flex-1 px-5 py-3 rounded-full border border-gold/30 bg-white focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all"
          />
          <button 
            type="submit" 
            class="px-8 py-3 rounded-full bg-warm-brown text-cream font-medium hover:bg-dark-brown transition-colors whitespace-nowrap"
          >
    Inschrijven
  </button>
        </form>

        <p id="newsletter-message" class="mt-4 text-sm hidden"></p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('newsletter-form');
  const message = document.getElementById('newsletter-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const email = formData.get('email');
    const name = formData.get('name');

    try {
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, name }),
      });

      const data = await response.json();
      
      if (response.ok) {
        message.textContent = '✓ ' + data.message;
        message.className = 'mt-4 text-sm text-green-600';
        form.reset();
      } else {
        message.textContent = data.error || 'Er ging iets mis';
        message.className = 'mt-4 text-sm text-red-500';
      }
    } catch {
      message.textContent = 'Er ging iets mis. Probeer het later opnieuw.';
      message.className = 'mt-4 text-sm text-red-500';
    }
    message.classList.remove('hidden');
  });
</script>
