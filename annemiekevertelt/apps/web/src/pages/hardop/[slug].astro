---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import PageTurn from '../../components/PageTurn';
import AudioPlayer from '../../components/AudioPlayer';
import { fetchBySlug } from '../../lib/payload';
import { formatDate } from '../../lib/date';
import { ArrowLeft, Calendar, Clock, Headphones } from 'lucide-react';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/hardop');
}

const audio = await fetchBySlug('audio-content', slug).catch(() => null);

if (!audio) {
  return Astro.redirect('/404');
}

const coverImageUrl = audio.coverImage 
  ? `${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${audio.coverImage.url}` 
  : null;

const audioFileUrl = audio.audioFile 
  ? `${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${audio.audioFile.url}` 
  : null;
---

<Layout 
  title={`${audio.title} | Hardop | Annemieke Vertelt`}
  description={audio.description}
  image={coverImageUrl}
>
  <Navigation />

  <PageTurn client:load>
    <article class="pt-28 pb-20 min-h-screen">
      <div class="container-readable">
        <!-- Back Link -->
        <a 
          href="/hardop" 
          class="inline-flex items-center gap-2 text-warm-brown hover:text-dark-brown transition-colors mb-8"
        >
          <ArrowLeft class="w-4 h-4" />
          <span class="text-sm">Terug naar hardop</span>
        </a>

        <!-- Header -->
        <header class="mb-12">
          <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted mb-4">
            <span class="flex items-center gap-1">
              <Calendar class="w-4 h-4" />
              <time datetime={audio.publishedDate}>
                {formatDate(audio.publishedDate)}
              </time>
            </span>
            <span>·</span>
            <span class="text-gold font-medium flex items-center gap-1">
              <Headphones class="w-4 h-4" />
              Hardop
            </span>
            <span>·</span>
            <span class="flex items-center gap-1">
              <Clock class="w-4 h-4" />
              {audio.duration}
            </span>
          </div>

          <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl text-dark-brown mb-6 leading-tight">
            {audio.title}
          </h1>

          {audio.description && (
            <p class="text-xl text-text-muted italic leading-relaxed">
              {audio.description}
            </p>
          )}
        </header>

        <!-- Audio Player -->
        <div class="mb-12">
          <AudioPlayer 
            client:load
            title={audio.title}
            audioUrl={audioFileUrl}
            coverImage={coverImageUrl}
            duration={audio.duration}
          />
        </div>

        <!-- Cover Image (if no audio or as additional visual) -->
        {coverImageUrl && !audioFileUrl && (
          <figure class="mb-12">
            <img 
              src={coverImageUrl}
              alt={audio.coverImage.alt || audio.title}
              class="w-full rounded-2xl shadow-lg"
            />
          </figure>
        )}

        <!-- Additional Content (optional transcript or notes) -->
        {audio.content && (
          <div class="mt-12 pt-8 border-t border-gold/20">
            <h2 class="font-serif text-2xl text-dark-brown mb-6">Bij het verhaal</h2>
            <div 
              class="prose prose-lg prose-warm max-w-none"
              set:html={audio.content}
            />
          </div>
        )}

        <!-- Share/Like Section -->
        <div class="mt-16 pt-8 border-t border-gold/20 text-center">
          <p class="text-text-muted mb-4">Vond je dit verhaal mooi?</p>
          
          <div class="flex items-center justify-center gap-4">
            <button class="flex items-center gap-2 px-6 py-3 rounded-full border border-gold/30 text-warm-brown hover:bg-gold/10 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
              <span>Bewaren</span>
            </button>

            <button class="flex items-center gap-2 px-6 py-3 rounded-full border border-gold/30 text-warm-brown hover:bg-gold/10 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
              </svg>
              <span>Delen</span>
            </button>
          </div>
        </div>
      </div>
    </article>
  </PageTurn>

  <Footer />
</Layout>
