---
import { fetchPayload } from '../lib/payload';

const columnsData = await fetchPayload({ collection: 'columns', limit: 3, where: { status: { equals: 'published' } } }).catch(() => ({ docs: [] }));
const storiesData = await fetchPayload({ collection: 'childrens-stories', limit: 3, where: { status: { equals: 'published' } } }).catch(() => ({ docs: [] }));
const audioData = await fetchPayload({ collection: 'audio-content', limit: 3, where: { status: { equals: 'published' } } }).catch(() => ({ docs: [] }));
const aboutData = await fetchPayload({ collection: 'about-me', limit: 3, where: { status: { equals: 'published' } } }).catch(() => ({ docs: [] }));

const hasContent = columnsData.docs.length > 0 || storiesData.docs.length > 0 || audioData.docs.length > 0 || aboutData.docs.length > 0;
---

<section class="py-20 bg-cream-dark/30">
  <div class="container-wide">
    <div class="text-center mb-16">
      <p class="text-warm-brown font-serif italic text-xl mb-2">Mocht je me gemist hebben…</p>
      <h2 class="text-4xl md:text-5xl font-serif text-dark-brown">Het laatste nieuws</h2>
    </div>

    {hasContent ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Columns -->
        {columnsData.docs.slice(0, 1).map((post: any) => (
          <a 
            href={`/columns/${post.slug}`} 
            class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg"
          >
            {post.featuredImage && (
              <div class="aspect-[4/3] overflow-hidden">
                <img 
                  src={`${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${post.featuredImage.url}`}
                  alt={post.featuredImage.alt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              <span class="text-xs font-medium tracking-wider text-gold uppercase">Column</span>
              <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3 group-hover:text-warm-brown transition-colors">{post.title}</h3>
              <p class="text-text-muted text-sm line-clamp-2">{post.excerpt}</p>
            </div>
          </a>
        ))}

        <!-- Children's Stories -->
        {storiesData.docs.slice(0, 1).map((post: any) => (
          <a 
            href={`/verhalen/${post.slug}`} 
            class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg"
          >
            {post.featuredImage && (
              <div class="aspect-[4/3] overflow-hidden">
                <img 
                  src={`${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${post.featuredImage.url}`}
                  alt={post.featuredImage.alt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              <span class="text-xs font-medium tracking-wider text-gold uppercase">Verhaal · {post.ageGroup}</span>
              <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3 group-hover:text-warm-brown transition-colors">{post.title}</h3>
              <p class="text-text-muted text-sm line-clamp-2">{post.excerpt}</p>
            </div>
          </a>
        ))}

        <!-- Audio Content -->
        {audioData.docs.slice(0, 1).map((post: any) => (
          <a 
            href={`/hardop/${post.slug}`} 
            class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg"
          >
            {post.coverImage && (
              <div class="aspect-[4/3] overflow-hidden">
                <img 
                  src={`${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${post.coverImage.url}`}
                  alt={post.coverImage.alt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              <span class="text-xs font-medium tracking-wider text-gold uppercase">Luisteren · {post.duration}</span>
              <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3 group-hover:text-warm-brown transition-colors">{post.title}</h3>
              <p class="text-text-muted text-sm line-clamp-2">{post.description && typeof post.description === 'string' ? post.description : 'Een verhaal om naar te luisteren'}</p>
            </div>
          </a>
        ))}

        <!-- About Me -->
        {aboutData.docs.slice(0, 1).map((post: any) => (
          <a 
            href={`/over-zichzelf/${post.slug}`} 
            class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg"
          >
            {post.featuredImage && (
              <div class="aspect-[4/3] overflow-hidden">
                <img 
                  src={`${import.meta.env.PAYLOAD_URL || 'http://localhost:3001'}${post.featuredImage.url}`}
                  alt={post.featuredImage.alt}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-6">
              <span class="text-xs font-medium tracking-wider text-gold uppercase">Over zichzelf</span>
              <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3 group-hover:text-warm-brown transition-colors">{post.title}</h3>
              <p class="text-text-muted text-sm line-clamp-2">{post.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <!-- Demo content for initial view -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Demo Column -->
        <div class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg">
          <div class="aspect-[4/3] overflow-hidden bg-gradient-to-br from-gold/20 to-gold/5 flex items-center justify-center">
            <svg class="w-16 h-16 text-gold/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-medium tracking-wider text-gold uppercase">Column</span>
            <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3">De kunst van het vertellen</h3>
            <p class="text-text-muted text-sm">Een reflectie over waarom verhalen ons mens maken…</p>
          </div>
        </div>

        <!-- Demo Story -->
        <div class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg">
          <div class="aspect-[4/3] overflow-hidden bg-gradient-to-br from-warm-brown/20 to-warm-brown/5 flex items-center justify-center">
            <svg class="w-16 h-16 text-warm-brown/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-medium tracking-wider text-gold uppercase">Verhaal · 6-8 jaar</span>
            <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3">De wolkendief</h3>
            <p class="text-text-muted text-sm">Een magisch verhaal over een meisje dat wolken kan vangen…</p>
          </div>
        </div>

        <!-- Demo Audio -->
        <div class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg">
          <div class="aspect-[4/3] overflow-hidden bg-gradient-to-br from-dark-brown/20 to-dark-brown/5 flex items-center justify-center">
            <svg class="w-16 h-16 text-dark-brown/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-medium tracking-wider text-gold uppercase">Luisteren · 15 min</span>
            <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3">Een avond in de herfst</h3>
            <p class="text-text-muted text-sm">Een sprookje voor het slapengaan, voorgelezen door Annemieke…</p>
          </div>
        </div>

        <!-- Demo About -->
        <div class="story-card group block bg-white rounded-2xl overflow-hidden shadow-lg">
          <div class="aspect-[4/3] overflow-hidden bg-gradient-to-br from-gold-light/30 to-gold/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-medium tracking-wider text-gold uppercase">Over zichzelf</span>
            <h3 class="text-xl font-serif text-dark-brown mt-2 mb-3">Hoe het begon</h3>
            <p class="text-text-muted text-sm">Het verhaal achter Annemieke Vertelt en waarom schrijven…</p>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
